{
  "name": "ethan-skill",
  "version": "1.0.0",
  "description": "Ethan - Your AI Workflow Assistant",
  "keywords": [
    "ai-skill",
    "cursor",
    "copilot",
    "cline",
    "lingma",
    "codebuddy",
    "mcp",
    "workflow"
  ],
  "author": "",
  "license": "MIT",
  "main": "dist/cli/index.js",
  "bin": {
    "ethan": "./dist/cli/index.js"
  },
  "files": [
    "dist/",
    "rules/",
    "README.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "build:rules": "npx ts-node scripts/build/build-rules.ts",
    "build:vscode": "npx ts-node scripts/build/build-vscode.ts",
    "build:mcp": "tsc -p tsconfig.json && echo 'MCP Server compiled'",
    "build:all": "npm run build && npm run build:rules",
    "dev": "tsc -p tsconfig.json --watch",
    "clean": "rm -rf dist/",
    "lint": "eslint src/ --ext .ts",
    "lint:fix": "eslint src/ --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "prepublishOnly": "npm run build:all && npm run lint && npm run test"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "chalk": "^5.3.0",
    "commander": "^12.0.0",
    "fs-extra": "^11.2.0",
    "ora": "^8.0.1"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.0",
    "@eslint/js": "^9.39.4",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^20.0.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.0",
    "typescript-eslint": "^8.57.1",
    "vitest": "^4.1.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/your-org/ethan-skill.git"
  }
}
