{
  "name": "smart-flow-skill",
  "version": "1.0.0",
  "description": "工作流自动执行助手 AI Skill - 跨平台分发包（Cursor、VS Code Copilot、Cline、通义灵码、腾讯 CodeBuddy）",
  "keywords": [
    "ai-skill",
    "cursor",
    "copilot",
    "cline",
    "lingma",
    "codebuddy",
    "mcp",
    "workflow"
  ],
  "author": "",
  "license": "MIT",
  "main": "dist/cli/index.js",
  "bin": {
    "smart-flow": "./dist/cli/index.js"
  },
  "files": [
    "dist/",
    "rules/",
    "README.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "build:rules": "npx ts-node scripts/build/build-rules.ts",
    "build:vscode": "npx ts-node scripts/build/build-vscode.ts",
    "build:mcp": "tsc -p tsconfig.json && echo 'MCP Server compiled'",
    "build:all": "npm run build && npm run build:rules",
    "dev": "tsc -p tsconfig.json --watch",
    "clean": "rm -rf dist/",
    "prepublishOnly": "npm run build:all"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "commander": "^12.0.0",
    "chalk": "^5.3.0",
    "ora": "^8.0.1",
    "fs-extra": "^11.2.0"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.0",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^20.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/your-org/smart-flow-skill.git"
  }
}
